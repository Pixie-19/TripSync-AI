# ── Supabase ──────────────────────────────────────────────
# Normal setup: point NEXT_PUBLIC_SUPABASE_URL at your Supabase project.
# ISP-block workaround (e.g. Jio in India blocks *.supabase.co):
#   1. Set SUPABASE_DIRECT_URL to the real Supabase URL.
#   2. Set NEXT_PUBLIC_SUPABASE_URL to https://<your-app-domain>/sb-proxy
#      (or http://localhost:3000/sb-proxy in dev).
# Next.js will reverse-proxy /sb-proxy/* → SUPABASE_DIRECT_URL/*, so all
# Supabase REST calls travel via your app domain and bypass the ISP block.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Only needed if using the /sb-proxy workaround above. Leave unset otherwise.
SUPABASE_DIRECT_URL=

# ── Firebase (used for Google Sign-In) ────────────────────
# After enabling Google as a sign-in provider in the Firebase console, copy
# the Web App config values here. Also add your prod domain (and localhost
# for dev) to Authentication → Settings → Authorized domains.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── AI ────────────────────────────────────────────────────
# Code currently calls Mistral (src/lib/ai.ts + /api/* routes).
MISTRAL_API_KEY=your_mistral_api_key

# ── Weather (OpenWeatherMap) ──────────────────────────────
NEXT_PUBLIC_OPENWEATHER_API_KEY=

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
